#!/bin/sh
# recipes/build — compile / install deps for every recipe.
# Idempotent. Skips a recipe if its toolchain isn't installed.

set -eu
HERE=$(cd "$(dirname "$0")" && pwd)

echo "==> recipes/build"

if command -v python3 >/dev/null 2>&1; then
  echo "  pythong: no build step (interpreted, stdlib + openssl(1))"
else
  echo "  pythong: skipped — python3 not found"
fi

if command -v node >/dev/null 2>&1; then
  echo "  node:    no build step (interpreted, zero deps)"
else
  echo "  node:    skipped — node not found"
fi

if command -v ruby >/dev/null 2>&1; then
  echo "  ruby:    no build step (interpreted, stdlib openssl)"
else
  echo "  ruby:    skipped — ruby not found"
fi

if command -v elixir >/dev/null 2>&1; then
  echo "  elixir:  no build step (script, OTP :crypto)"
else
  echo "  elixir:  skipped — elixir not found"
fi

if command -v java >/dev/null 2>&1; then
  echo "  java:    no build step (single-file source launch, JDK stdlib)"
else
  echo "  java:    skipped — java not found"
fi

if command -v dotnet >/dev/null 2>&1; then
  echo "  csharp:  dotnet build -c Release"
  ( cd "$HERE/csharp" && dotnet build -c Release --nologo -v quiet >/dev/null )
  echo "  csharp:  ok ($HERE/csharp/bin/Release/net8.0/xenv-recipe)"
else
  echo "  csharp:  skipped — dotnet not found"
fi

if command -v go >/dev/null 2>&1; then
  echo "  go:      prefetching x/crypto"
  ( cd "$HERE/go" && go mod tidy >/dev/null 2>&1 ) || true
  echo "  go:      ok"
else
  echo "  go:      skipped — go not found"
fi

if command -v cargo >/dev/null 2>&1; then
  echo "  rust:    cargo build --release"
  ( cd "$HERE/rust" && cargo build --release --quiet )
  echo "  rust:    ok ($HERE/rust/target/release/xenv-recipe)"
else
  echo "  rust:    skipped — cargo not found"
fi

echo "==> done. run recipes/try for a demo, recipes/test for assertions."
