{
  "name": "xenv",
  "version": "1.0.0",
  "description": "AI-native secrets manager with AES-256-GCM encryption, MCP server, and zero dependencies. Drop-in dotenv alternative.",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "xenv": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --compile --minify --target=bun-linux-x64 --outfile=xenv",
    "build:all": "bun run scripts/build-all.ts",
    "test": "bun test",
    "site:build": "bun run site/build.ts",
    "site:preview": "bun run site/build.ts && cd site/dist && python3 -m http.server 8080"
  },
  "keywords": [
    "env",
    "secrets",
    "encryption",
    "dotenv",
    "dotenv-alternative",
    "dotenvx-alternative",
    "direnv-alternative",
    "environment",
    "vault",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "ai-native",
    "secrets-management",
    "secrets-manager",
    "environment-variables",
    "environment-runner",
    "aes-256-gcm",
    "zero-dependency",
    "single-binary",
    "encrypted-env"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ahoward/xenv.git"
  },
  "homepage": "https://xenv.sh",
  "bugs": {
    "url": "https://github.com/ahoward/xenv/issues"
  },
  "license": "MIT",
  "author": "mountainhigh.codes (https://drawohara.io)"
}
