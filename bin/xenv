#!/bin/sh
# xenv — per-key encrypted environment store
#
# Project layout (after `xenv setup`):
#
#   xenv
#   ├── README.md                  — frontmatter (project id) + docs
#   ├── bin
#   │   └── xenv                   — self-contained copy of this script
#   └── envs
#       ├── development
#       │   ├── APP_ENV.value.enc
#       │   └── README.md
#       ├── production
#       │   ├── APP_ENV.value.enc  — one encrypted variable per file
#       │   ├── DATABASE_URL.value.enc
#       │   └── README.md          — frontmatter (KDF params) + per-env docs
#       ├── staging
#       │   ├── APP_ENV.value.enc
#       │   └── README.md
#       └── testing
#           ├── APP_ENV.value.enc
#           └── README.md
#
# Every README.md opens with YAML frontmatter holding the metadata
# for its directory. Keys are simple (version, iter, salt, id) — the
# file's location implies whether they describe the project or an env.
#
# Every file under xenv/ is SAFE TO COMMIT by design. The whole `xenv/`
# directory is the project's environment store — code, config, and data
# in one place. `rm -rf xenv/` ejects the tool cleanly.
#
# Threat model: dev tool for one human or a small trusted team. Protects
# against accidental plaintext commits and lost laptops. Does NOT protect
# against an attacker running commands as the same user — they've already won.
#
# Dependencies: sh, openssl (3.0+ for kdf), awk, mktemp, od.

set -u
LC_ALL=C
export LC_ALL

XENV_VERSION="0.9.0-posix"
XENV_DIR="xenv"
XENV_VAULT_VERSION="v3"
XENV_PROJECT_FORMAT="v1"
XENV_ITER=200000
XENV_SALT_BYTES=16
XENV_IV_BYTES=16
XENV_KEY_BYTES=32
XENV_MAC_BYTES=32
XENV_VALUE_EXT=".value.enc"
XENV_README_FILE="README.md"
XENV_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/xenv"
XENV_PROJECTS_DIR="$XENV_CONFIG/projects"

XENV_DEFAULT_ENVS="testing development staging production"

# ── output ────────────────────────────────────────────────────────

err()  { printf 'xenv: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
info() { printf 'xenv: %s\n' "$*" >&2; }

# ── hex helpers (POSIX awk, no xxd) ───────────────────────────────

# stdin: arbitrary bytes  →  stdout: lowercase hex (no whitespace).
# uses `od` which is POSIX everywhere; xxd is not guaranteed.
hex_encode() {
  od -An -vtx1 | tr -d '[:space:]'
}

# stdin: lowercase hex  →  stdout: arbitrary bytes.
# inverse of hex_encode. pure awk, no external deps.
hex_decode() {
  awk '
    BEGIN {
      for (i = 0; i < 16; i++) {
        c = sprintf("%x", i); v[c] = i; v[toupper(c)] = i
      }
    }
    {
      for (i = 1; i <= length($0); i += 2) {
        printf "%c", v[substr($0,i,1)] * 16 + v[substr($0,i+1,1)]
      }
    }
  '
}

# ── project id ────────────────────────────────────────────────────
#
# Every initialized project gets a unique id, stored in YAML
# frontmatter at the top of xenv/README.md:
#
#   ---
#   # xenv project state — DO NOT EDIT — managed by xenv
#   version: v1
#   id: <sanitized-basename>--<32-hex-uuid>
#   ---
#
# The id is human-readable (so you can `ls ~/.config/xenv/projects/`
# and recognize what's what) but disambiguated by 128 bits of
# randomness (so two projects with the same basename never collide).
#
# Per-project state lives in:
#
#   ~/.config/xenv/projects/<id>/
#     keys/<env>     ← passphrases, mode 600 (never committed)
#     origin        ← absolute path of xenv/ at last init (informational)
#     notes.md      ← user's per-project notebook (survives the project)
#
# The id is safe to commit. It carries no secret — it's just the
# identifier that binds a checkout to a local keys directory.
# Teammates cloning the same repo share the project id and each set
# up their own local passphrase under their own
# ~/.config/xenv/projects/<id>/.

# turn a project basename into something filesystem-friendly. lowercase,
# replace any non-[A-Za-z0-9._-] with -, collapse runs of -, trim leading/
# trailing -. Empty result becomes "project".
sanitize_basename() {
  printf '%s' "$1" | awk '
    {
      out = tolower($0)
      n = ""
      prev = ""
      for (i = 1; i <= length(out); i++) {
        c = substr(out, i, 1)
        if (c ~ /[A-Za-z0-9._-]/) {
          n = n c
          prev = c
        } else if (prev != "-") {
          n = n "-"
          prev = "-"
        }
      }
      # trim leading and trailing -
      sub(/^-+/, "", n)
      sub(/-+$/, "", n)
      if (n == "") n = "project"
      print n
    }
  '
}

# generate a new project id from the current cwd's basename + 32 hex random
new_project_id() {
  base=$(sanitize_basename "$(basename "$(pwd)")")
  uuid=$(openssl rand -hex 16)
  printf '%s--%s' "$base" "$uuid"
}

# read the project id from xenv/README.md frontmatter.
# errors if missing or malformed.
read_project_id() {
  rf="$XENV_DIR/$XENV_README_FILE"
  [ -f "$rf" ] || { err "no $rf — run 'xenv setup'"; return 1; }

  ver=""; id=""
  while read -r k v; do
    case "$k" in
      version) ver=$v ;;
      id)      id=$v ;;
    esac
  done <<EOF
$(read_frontmatter "$rf")
EOF

  [ -n "$ver" ]                    || { err "$rf: no project version in frontmatter"; return 1; }
  [ "$ver" = "$XENV_PROJECT_FORMAT" ] \
    || { err "$rf: unsupported project version $ver"; return 1; }
  [ -n "$id" ]                     || { err "$rf: no project id in frontmatter"; return 1; }
  # sanity: id should be sanitized-basename--32hex.
  case "$id" in
    *--*) ;;
    *) err "$rf: malformed project id"; return 1 ;;
  esac
  printf '%s' "$id"
}

# return ~/.config/xenv/projects/<id>/ for the current project.
project_dir() {
  id=$(read_project_id) || return 1
  printf '%s/%s' "$XENV_PROJECTS_DIR" "$id"
}

# initialize the per-project config dir: keys/, origin, notes.md
init_project_dir() {
  id=$1
  origin=$2
  pdir="$XENV_PROJECTS_DIR/$id"

  mkdir -p "$pdir/keys"
  chmod 700 "$XENV_CONFIG" "$XENV_PROJECTS_DIR" "$pdir" "$pdir/keys" 2>/dev/null || true

  umask 077
  printf '%s\n' "$origin" > "$pdir/origin"
  chmod 600 "$pdir/origin"

  # notes.md is the user's per-project notebook. starts as a stub.
  basename_part=${id%%--*}
  cat > "$pdir/notes.md" <<EOF
# $basename_part

Notes for the xenv keys for this project.

- Origin: $origin
- Project ID: $id
- Initialized: $(date -u +%Y-%m-%dT%H:%M:%SZ)

## ops notes

Write anything useful here. Examples:

- Who else has access to these secrets?
- Where do the production values come from?
- Last rotated when?
- Recovery procedure if the keychain is wiped?
EOF
  chmod 600 "$pdir/notes.md"
}

# ── crypto ────────────────────────────────────────────────────────
#
# Per-env KDF parameters live in the YAML frontmatter at the top of
# xenv/envs/<env>/README.md:
#
#   ---
#   # xenv crypto state — DO NOT EDIT — managed by xenv
#   version: v3
#   iter: 200000
#   salt: 7a2c4f8e1b9d3a6f5e8c2b0a4d7e9f1c
#   ---
#
# Keys are bare. The file's location implies the scope; no need to
# spell "xenv_iter" when you're in a file under xenv/envs/<env>/.
#
# The parser is naive on purpose: for each line in the block, split on
# the FIRST ':', trim both sides. No quoting, no types, no nesting. The
# README body below the frontmatter is free for humans/agents to edit.
#
# Per-value envelope (one line in each KEY.value.enc):
#   xenv:v3:<iv-hex>:<ct-hex>:<mac-hex>
#
# MAC is HMAC-SHA256 over "v3:<iv-hex>:<ct-hex>" using a separate derived key.
# Version is part of the MAC, so future v4 envelopes can't be confused with v3.

# derive an encryption key and a MAC key from a passphrase.
#   args: <passphrase> <salt-hex> <iter>
#   kdf:  PBKDF2-SHA256, yields 64 bytes (32 enc-key || 32 mac-key)
#   out:  "<enc-key-hex> <mac-key-hex>" on stdout
# any language with PBKDF2-SHA256 + HMAC-SHA256 + AES-256-CBC can do this.
derive_keys() {
  passphrase=$1
  salt_hex=$2
  iter=$3
  total=$((XENV_KEY_BYTES + XENV_MAC_BYTES))

  derived=$(
    openssl kdf -keylen "$total" -kdfopt digest:SHA256 \
      -kdfopt "pass:$passphrase" -kdfopt "hexsalt:$salt_hex" \
      -kdfopt "iter:$iter" -binary PBKDF2 2>/dev/null \
      | hex_encode
  )
  [ -n "$derived" ] || { err "key derivation failed (need openssl 3.0+)"; return 1; }

  printf '%s' "$derived" | awk -v n=$((XENV_KEY_BYTES * 2)) \
    '{ printf "%s %s\n", substr($0,1,n), substr($0,n+1) }'
}

# encrypt one value into a v3 envelope.
#   args:   <enc-key-hex> <mac-key-hex>   (from derive_keys)
#   stdin:  plaintext bytes (any contents — newlines, binary, etc.)
#   stdout: "xenv:v3:<iv-hex>:<ct-hex>:<mac-hex>"
#   cipher: AES-256-CBC, random 16-byte IV
#   mac:    HMAC-SHA256 over "v3:<iv-hex>:<ct-hex>" — encrypt-then-MAC,
#           version is in the MAC scope so future formats can't be confused.
encrypt_value() {
  enc_key_hex=$1
  mac_key_hex=$2
  iv_hex=$(openssl rand -hex "$XENV_IV_BYTES")

  ct_hex=$(openssl enc -aes-256-cbc -K "$enc_key_hex" -iv "$iv_hex" 2>/dev/null | hex_encode)
  [ -n "$ct_hex" ] || { err "encryption failed"; return 1; }

  mac_input="${XENV_VAULT_VERSION}:${iv_hex}:${ct_hex}"
  mac_hex=$(printf '%s' "$mac_input" \
    | openssl dgst -sha256 -mac HMAC -macopt hexkey:"$mac_key_hex" -binary 2>/dev/null \
    | hex_encode)
  [ -n "$mac_hex" ] || { err "MAC computation failed"; return 1; }

  printf 'xenv:%s:%s:%s:%s\n' "$XENV_VAULT_VERSION" "$iv_hex" "$ct_hex" "$mac_hex"
}

# decrypt one v3 envelope.
#   args:   <enc-key-hex> <mac-key-hex>   (from derive_keys)
#   stdin:  "xenv:v3:<iv-hex>:<ct-hex>:<mac-hex>" (one line)
#   stdout: plaintext bytes
#   order:  parse → field-shape checks → MAC verify → decrypt.
#           MAC is verified BEFORE decrypt (encrypt-then-MAC discipline).
decrypt_value() {
  enc_key_hex=$1
  mac_key_hex=$2
  envelope=$(cat)

  IFS=: read -r tag ver iv_hex ct_hex mac_hex extra <<EOF
$envelope
EOF

  [ "$tag" = "xenv" ]                   || { err "not an xenv envelope"; return 1; }
  [ "$ver" = "$XENV_VAULT_VERSION" ]    || { err "unsupported vault version: $ver"; return 1; }
  [ -z "$extra" ]                       || { err "envelope has extra fields"; return 1; }
  [ "${#iv_hex}" -eq 32 ]               || { err "invalid iv length"; return 1; }
  [ "${#mac_hex}" -eq 64 ]              || { err "invalid mac length"; return 1; }
  [ "${#ct_hex}" -gt 0 ] && [ $((${#ct_hex} % 32)) -eq 0 ] \
                                        || { err "invalid ciphertext length"; return 1; }
  case "$iv_hex$ct_hex$mac_hex" in
    *[!0-9a-f]*) err "envelope contains non-hex"; return 1 ;;
  esac

  mac_input="${ver}:${iv_hex}:${ct_hex}"
  expected=$(printf '%s' "$mac_input" \
    | openssl dgst -sha256 -mac HMAC -macopt hexkey:"$mac_key_hex" -binary 2>/dev/null \
    | hex_encode)

  # Constant-time MAC verification: don't compare the MAC hexes directly
  # (shell's `=` short-circuits on first byte differ, leaking a timing
  # side-channel). Instead, HMAC each side under a fresh per-call key
  # and compare those — the attacker now sees timing on values they
  # can't predict, so no byte-by-byte bisection is possible. Same trick
  # the formal HMAC-verify literature recommends.
  cmp_key=$(openssl rand -hex 32)
  mac_a=$(printf '%s' "$mac_hex"  | openssl dgst -sha256 -mac HMAC -macopt hexkey:"$cmp_key" -binary 2>/dev/null | hex_encode)
  mac_b=$(printf '%s' "$expected" | openssl dgst -sha256 -mac HMAC -macopt hexkey:"$cmp_key" -binary 2>/dev/null | hex_encode)
  [ "$mac_a" = "$mac_b" ] || { err "MAC verification failed — wrong key or tampered vault"; return 1; }

  printf '%s' "$ct_hex" | hex_decode \
    | openssl enc -d -aes-256-cbc -K "$enc_key_hex" -iv "$iv_hex" 2>/dev/null
}

# ── per-env directory + params (in README frontmatter) ────────────

env_dir()     { printf '%s/envs/%s' "$XENV_DIR" "$1"; }
value_file()  { printf '%s/envs/%s/%s%s' "$XENV_DIR" "$1" "$2" "$XENV_VALUE_EXT"; }
readme_file() { printf '%s/envs/%s/%s' "$XENV_DIR" "$1" "$XENV_README_FILE"; }

# read_frontmatter <file> — extract the YAML frontmatter block at the
# top of <file> and emit "key value" lines, one per setting. Naive on
# purpose: split each line at the FIRST ':', trim both sides. Nothing
# more. Lines starting with '#' (after trim) and blank lines are skipped.
# A file with no '---' fence prints nothing (callers handle the empty case).
read_frontmatter() {
  awk '
    function trim(s) {
      sub(/^[ \t]+/, "", s)
      sub(/[ \t\r]+$/, "", s)
      return s
    }
    NR == 1 {
      if ($0 != "---") exit 0
      in_block = 1
      next
    }
    in_block && $0 == "---" { exit 0 }
    in_block {
      line = trim($0)
      if (line == "" || substr(line, 1, 1) == "#") next
      i = index(line, ":")
      if (i == 0) next
      key = trim(substr(line, 1, i - 1))
      val = trim(substr(line, i + 1))
      if (key != "") print key, val
    }
  ' "$1"
}

read_params() {
  env_name=$1
  rf=$(readme_file "$env_name")
  [ -f "$rf" ] || { err "no README for '$env_name' — run 'xenv key generate @$env_name' first"; return 1; }

  ver=""; iter=""; salt_hex=""
  while read -r k v; do
    case "$k" in
      version) ver=$v ;;
      iter)    iter=$v ;;
      salt)    salt_hex=$v ;;
    esac
  done <<EOF
$(read_frontmatter "$rf")
EOF

  [ -n "$ver" ]                      || { err "params: no version in $rf frontmatter"; return 1; }
  [ "$ver" = "$XENV_VAULT_VERSION" ] || { err "params: unsupported version $ver"; return 1; }
  [ "${#salt_hex}" -eq 32 ]          || { err "params: invalid salt length"; return 1; }
  case "$salt_hex" in
    *[!0-9a-f]*) err "params: non-hex salt"; return 1 ;;
  esac
  case "$iter" in
    ""|*[!0-9]*) err "params: invalid iter"; return 1 ;;
  esac

  printf '%s %s\n' "$iter" "$salt_hex"
}

# write_frontmatter <env> <iter> <salt-hex> — emit the frontmatter block
# that goes at the very top of the per-env README. Always the same shape,
# always the same warning. Crypto state in three flat keys.
write_frontmatter() {
  env_name=$1
  iter=$2
  salt_hex=$3
  cat <<EOF
---
# xenv crypto state — DO NOT EDIT — managed by xenv
# changing these breaks decryption. rotate with: xenv key rotate @$env_name
version: $XENV_VAULT_VERSION
iter: $iter
salt: $salt_hex
---
EOF
}

# initialize a new env dir. must not exist yet. The README (with
# frontmatter holding fresh KDF params) is written by write_env_readme.
init_env_dir() {
  env_name=$1
  dir=$(env_dir "$env_name")
  [ -d "$dir" ] && die "env '$env_name' already exists at $dir"

  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true
}

# ── passphrase resolution ─────────────────────────────────────────

env_var_name() {
  printf 'XENV_KEY_%s' "$(printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_')"
}

# lookup_key <env> — find the passphrase for <env>, walking the cascade:
#
#   1. $XENV_KEY_<ENV>                            env-specific env var
#   2. $XENV_KEY                                  project-wide env var
#   3. keys/<env>.key                             env-specific file
#   4. keys/_global.key                           project-wide file
#   5. macOS keychain xenv/<id>/<env>             env-specific keychain
#   6. macOS keychain xenv/<id>/_global           project-wide keychain
#   7. pass xenv/<id>/<env>                       env-specific pass
#   8. pass xenv/<id>/_global                     project-wide pass
#
# Env-specific beats global within each backend class. First non-empty
# slot wins. Returns the raw passphrase on stdout, or non-zero if none.
lookup_key() {
  env_name=$1
  vname=$(env_var_name "$env_name")

  eval "val=\${$vname:-}"
  [ -n "$val" ] && { printf '%s' "$val"; return 0; }
  [ -n "${XENV_KEY:-}" ] && { printf '%s' "$XENV_KEY"; return 0; }

  # the rest are project-scoped, so two projects with same env names
  # never share keys.
  id=$(read_project_id 2>/dev/null) || return 1

  for stem in "$env_name" "_global"; do
    f="$XENV_PROJECTS_DIR/$id/keys/$stem.key"
    [ -r "$f" ] && { cat "$f"; return 0; }
  done

  if command -v security >/dev/null 2>&1; then
    for stem in "$env_name" "_global"; do
      val=$(security find-generic-password -s xenv -a "$id/$stem" -w 2>/dev/null) || true
      [ -n "$val" ] && { printf '%s\n' "$val"; return 0; }
    done
  fi

  if command -v pass >/dev/null 2>&1; then
    for stem in "$env_name" "_global"; do
      val=$(pass show "xenv/$id/$stem" 2>/dev/null) || true
      [ -n "$val" ] && { printf '%s\n' "$val"; return 0; }
    done
  fi

  return 1
}

require_key() {
  env_name=$1
  key=$(lookup_key "$env_name") || {
    vname=$(env_var_name "$env_name")
    id=$(read_project_id 2>/dev/null || printf '(no project)')
    err "no key for '$env_name' (project: $id)"
    err "tried: \$$vname, \$XENV_KEY, $XENV_PROJECTS_DIR/$id/keys/{$env_name,_global}.key, keychain, pass"
    err "run 'xenv key generate @$env_name' to generate one, or 'xenv key set @$env_name' to provide one"
    return 1
  }
  printf '%s' "$key"
}

# store_key <env-or-_global> <passphrase> <backend>
#
# Pass the literal string "_global" as the first arg to write the
# project-wide key. Otherwise the env name. Backend "auto" means file.
store_key() {
  env_name=$1
  key=$2
  backend=${3:-auto}
  case "$backend" in
    --keychain) backend=keychain ;;
    --pass)     backend=pass ;;
    --file)     backend=file ;;
  esac

  # all backends are scoped by project id
  id=$(read_project_id) || die "cannot store key without a project id"

  case "$backend" in
    keychain)
      command -v security >/dev/null 2>&1 || die "macOS keychain unavailable"
      security add-generic-password -s xenv -a "$id/$env_name" -w "$key" -U 2>/dev/null
      info "key stored in macOS keychain (service=xenv, account=$id/$env_name)"
      ;;
    pass)
      command -v pass >/dev/null 2>&1 || die "pass unavailable"
      printf '%s\n' "$key" | pass insert -e "xenv/$id/$env_name" >/dev/null
      info "key stored in pass (xenv/$id/$env_name)"
      ;;
    file|auto)
      pdir="$XENV_PROJECTS_DIR/$id"
      mkdir -p "$pdir/keys"
      chmod 700 "$XENV_CONFIG" "$XENV_PROJECTS_DIR" "$pdir" "$pdir/keys" 2>/dev/null || true
      umask 077
      printf '%s\n' "$key" > "$pdir/keys/$env_name.key"
      chmod 600 "$pdir/keys/$env_name.key"
      info "key stored at $pdir/keys/$env_name.key (mode 600)"
      ;;
    *) die "unknown backend: $backend" ;;
  esac
}

# ── derive helpers for commands ───────────────────────────────────

keys_for_env() {
  env_name=$1
  passphrase=$(require_key "$env_name") || return 1
  params=$(read_params "$env_name") || return 1
  iter=${params%% *}
  salt_hex=${params#* }
  derive_keys "$passphrase" "$salt_hex" "$iter"
}

atomic_write() {
  dest=$1
  tmp="${dest}.tmp.$$"
  umask 077
  cat > "$tmp" || { rm -f "$tmp"; return 1; }
  mv "$tmp" "$dest"
}

# tty_finish — pass stdin to stdout. if FD 1 is a tty, guarantee at
# least one trailing newline so the next shell prompt isn't glued to
# the value; if it's a pipe / redirect, pass bytes verbatim so
# `db=$(xenv get prod URL)` still works exactly.
#
# We rely on awk's record model: awk reads records separated by RS
# (default \n) and `print` appends ORS (default \n). Input ending in
# \n round-trips to one \n (the trailing \n is the separator, not
# part of the last record); input not ending in \n gains exactly one.
tty_finish() {
  if [ -t 1 ]; then
    awk '{ print }'
  else
    cat
  fi
}

# encrypt a value and write it to xenv/<env>/KEY.value.enc atomically
write_value() {
  env_name=$1
  name=$2
  value=$3

  read -r enc_key mac_key <<EOF
$(keys_for_env "$env_name")
EOF
  [ -n "$enc_key" ] || return 1

  envelope=$(printf '%s' "$value" | encrypt_value "$enc_key" "$mac_key") \
    || { err "encryption failed — $name unchanged"; return 1; }
  printf '%s\n' "$envelope" | atomic_write "$(value_file "$env_name" "$name")"
}

# ── README templates ─────────────────────────────────────────────

# top-level xenv/README.md — frontmatter (project id) + docs.
# The id is the only piece of project-scope metadata: a 128-bit-random
# identifier that binds this checkout to ~/.config/xenv/projects/<id>/.
write_top_readme() {
  project_id=$1
  {
    cat <<EOF
---
# xenv project state — DO NOT EDIT — managed by xenv
# id binds this checkout to ~/.config/xenv/projects/<id>/
version: $XENV_PROJECT_FORMAT
id: $project_id
---
EOF
    cat <<'EOF'

# xenv/

## NAME

xenv/ — this project's encrypted environment store

## TL;DR;

🤖 The ENV for AI — encrypted, per-key, safe-to-commit env vars.
POSIX. Zero dependencies. Zero lock-in. Git- and agent-friendly.

**Tool source**: <https://github.com/ahoward/xenv>. An agent reading
this README can clone that repo to inspect the script, the test
suite, and the wire format documentation. The script itself lives
at `xenv/bin/xenv` inside *this* project — a self-contained copy.

## for humans

```sh
xenv list @<env>                   # show variable names
xenv get  @<env> KEY               # decrypt one value (silent on success)
xenv set  @<env> KEY=value         # store a value
xenv set  @<env> KEY < file        # store a multi-line/binary value
xenv edit @<env> KEY               # decrypt → $EDITOR → re-encrypt
xenv run  @<env> CMD [args]        # run a command with the env injected
xenv @<env>    CMD [args]          # shorthand: `xenv @production ./server`
xenv @<env>                        # no CMD: print KEY=value lines for the env
```

See `xenv help` for the full command list. Each env in `xenv/envs/`
has its own `README.md` documenting the variables that env uses.

## for agents

Every file in `xenv/` is **safe to commit and safe to share**:

- `*.value.enc` — AES-256-CBC encrypted, useless without the passphrase
- `README.md` — plain documentation. The top-level README holds the
  project id in its frontmatter; per-env READMEs hold the public KDF
  salt + iteration count in theirs. Neither is secret.

The **passphrase** is what you must never commit. It lives outside the
repo in one of (first hit wins):

  1. `$XENV_KEY_<ENV>` — environment variable
  2. `$XENV_KEY` — global env var
  3. `~/.config/xenv/projects/<project-id>/keys/<env>` — file, mode 600
  4. macOS keychain (account `<project-id>/<env>`, service `xenv`)
  5. `pass show xenv/<project-id>/<env>`

The project id lives in this README's frontmatter and binds this
checkout to a local keys directory. It is safe to commit.

To add a new value:

    xenv set @<env> KEY=value

To read one (script-safe, silent on success):

    xenv get @<env> KEY

To run a command with all the env's vars injected:

    xenv run @<env> ./your-command

**Never** decrypt to a plaintext file you might `git add`. There's
no need — use `xenv get` (in-memory) or `xenv run` (exec-time).

## xenv is just a posix helper

The encrypt/decrypt functions in `bin/xenv` *are* the spec. Three
functions, each ~15 lines:

- `derive_keys`    — `passphrase + salt + iter → enc-key + mac-key`. PBKDF2-SHA256.
- `encrypt_value`  — plaintext → `xenv:v3:<iv>:<ct>:<mac>`. AES-256-CBC + HMAC-SHA256.
- `decrypt_value`  — envelope → plaintext. MAC verify first, then decrypt.

Read those three functions and you've read xenv. No proprietary
format, no library lock-in, no runtime.

The upstream repo ships reference recipes at
<https://github.com/ahoward/xenv/tree/main/recipes>, all generated
from a single `recipes/README.md` you can feed to any coding agent.
Python, Node, Go, Rust, and a PHP recipe built by Gemini from that
README alone.

If this tool ever disappeared, your data wouldn't.

## structure

    xenv
    ├── README.md                  ← this file (frontmatter: project id)
    ├── bin
    │   └── xenv                   ← self-contained copy of the script
    └── envs
        ├── development
        │   ├── APP_ENV.value.enc
        │   └── README.md
        ├── production
        │   ├── APP_ENV.value.enc  ← one encrypted variable per file
        │   ├── …                  ← (add more with `xenv set @production K=v`)
        │   └── README.md          ← frontmatter (KDF params) + per-env docs
        ├── staging
        │   ├── APP_ENV.value.enc
        │   └── README.md
        └── testing
            ├── APP_ENV.value.enc
            └── README.md
EOF
  } > "$XENV_DIR/README.md"
}

# write a fresh per-env README. <iter> and <salt-hex> go into the
# frontmatter (which is what subsequent crypto calls read via read_params).
write_env_readme() {
  env_name=$1
  iter=$2
  salt_hex=$3
  {
    write_frontmatter "$env_name" "$iter" "$salt_hex"
    cat <<EOF

# xenv/$env_name

(Document the variables this env needs as you go. See \`xenv help\` and
\`xenv/README.md\` for commands and passphrase resolution.)
EOF
  } > "$(readme_file "$env_name")"
}

# rewrite the frontmatter of an existing README, preserving the body.
# called by rotate so user/agent edits to the prose survive a key rotation.
rewrite_frontmatter() {
  env_name=$1
  iter=$2
  salt_hex=$3
  rf=$(readme_file "$env_name")
  [ -f "$rf" ] || die "no README at $rf to rewrite"

  # strip any existing frontmatter, keep the body verbatim
  body=$(awk '
    NR == 1 && $0 == "---" { in_block = 1; next }
    in_block && $0 == "---" { in_block = 0; stripped = 1; next }
    in_block { next }
    { print }
  ' "$rf")

  {
    write_frontmatter "$env_name" "$iter" "$salt_hex"
    printf '%s\n' "$body"
  } | atomic_write "$rf"
}

# ── commands ──────────────────────────────────────────────────────

cmd_help() {
  cat <<'USAGE'
xenv — per-key encrypted environment store

usage:
  xenv setup                         bootstrap: create xenv/ (if absent),
                                     or adopt existing (prompts per env)
  xenv environments                  list environments
  xenv help | version

  xenv key generate [@<env>] [--keychain|--pass|--file]
                                     generate a passphrase (no @env: global)
  xenv key set      [@<env>] [--keychain|--pass|--file] [--force]
                                     read passphrase from stdin/tty,
                                     MAC-verify, cache (no @env: global)
  xenv key rotate   [@<env>]         rotate passphrase + re-encrypt
                                     (no @env: rotate _global, affects only
                                     envs without a per-env key)
  xenv key show     [@<env>] [--reveal]
                                     show storage location (or value)
  xenv key forget   [@<env>]         rm cached passphrase, leave vault

  xenv set    @<env> KEY=value       store a value
  xenv set    @<env> KEY             read value from stdin (multi-line OK)
  xenv get    @<env> KEY             decrypt one key (silent on success)
  xenv unset  @<env> KEY             delete a key
  xenv list   @<env>                 list key names (no decryption)
  xenv edit   @<env> KEY             decrypt → $VISUAL/$EDITOR → re-encrypt

  xenv run    @<env> CMD [args]      run command with all keys exported
  xenv @<env>      CMD [args]        shorthand for run
  xenv @<env>                        no CMD: print KEY=value lines

each env is a directory: xenv/envs/<env>/
each variable is one file: xenv/envs/<env>/KEY.value.enc
KDF params live in the per-env README's YAML frontmatter (safe to commit)

argv contract: @<env> can appear ANYWHERE in argv. these are equivalent:
  xenv get @production API_KEY
  xenv @production get API_KEY
  xenv get API_KEY @production

passphrase cascade (first hit wins, env-specific beats global per backend):
  1. $XENV_KEY_<ENV>                              env-specific env var
  2. $XENV_KEY                                    project-wide env var
  3. ~/.config/xenv/projects/<id>/keys/<env>.key  env-specific file
  4. ~/.config/xenv/projects/<id>/keys/_global.key project-wide file
  5. macOS keychain xenv/<id>/<env>               env-specific keychain
  6. macOS keychain xenv/<id>/_global             project-wide keychain
  7. pass xenv/<id>/<env>                         env-specific pass
  8. pass xenv/<id>/_global                       project-wide pass

default `xenv setup` (no env vars pinned) writes ONE _global.key — all four
default envs share it. split an env off later with `xenv key rotate @<env>`.
USAGE
}

cmd_version() { printf 'xenv %s\n' "$XENV_VERSION"; }

# read a passphrase from stdin or tty. If stdin is a tty, prompt with
# no-echo via stty(1). Otherwise read one line from stdin (CI / piped).
# prints the passphrase on stdout (no trailing newline).
read_passphrase() {
  prompt=$1
  if [ -t 0 ] && [ -t 2 ]; then
    # interactive: prompt to stderr, read with no-echo
    printf '%s' "$prompt" >&2
    stty -echo 2>/dev/null
    IFS= read -r pp
    rc=$?
    stty echo 2>/dev/null
    printf '\n' >&2
    [ $rc -eq 0 ] || return 1
    printf '%s' "$pp"
  else
    # non-tty: read one line. POSIX read returns non-zero on EOF
    # without trailing newline, but still assigns the partial input
    # to the variable. So we accept either: any non-empty $pp counts.
    pp=
    IFS= read -r pp || true
    [ -n "$pp" ] || return 1
    printf '%s' "$pp"
  fi
}

# verify_passphrase <env> <passphrase> — try decrypting one .value.enc
# in the env with the given passphrase. Returns 0 if MAC verifies, 1
# otherwise. Returns 2 if the env has no values to verify against
# (caller decides what to do — usually "warn + accept").
verify_passphrase() {
  env_name=$1
  passphrase=$2
  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || return 1

  params=$(read_params "$env_name") || return 1
  iter=${params%% *}
  salt_hex=${params#* }
  read -r enc_key mac_key <<EOF
$(derive_keys "$passphrase" "$salt_hex" "$iter")
EOF
  [ -n "$enc_key" ] || return 1

  for f in "$dir"/*"$XENV_VALUE_EXT"; do
    [ -f "$f" ] || continue
    decrypt_value "$enc_key" "$mac_key" < "$f" >/dev/null 2>&1 && return 0
    return 1   # MAC failed on the first value we tried
  done
  return 2   # no values to verify against
}

# bootstrap a fresh project: write tree, generate or honor pinned
# passphrases, stash keys. Called by cmd_setup when ./xenv/ is absent.
setup_fresh() {
  mkdir -p "$XENV_DIR/bin" "$XENV_DIR/envs"

  project_id=$(new_project_id)
  write_top_readme "$project_id"

  origin=$(cd "$XENV_DIR" && pwd)
  init_project_dir "$project_id" "$origin"

  # copy ourselves into xenv/bin/xenv so the project is self-contained.
  self=$0
  case "$self" in
    /*) ;;
    *)  self=$(command -v "$self" 2>/dev/null || printf '%s' "$self") ;;
  esac
  cp "$self" "$XENV_DIR/bin/xenv" 2>/dev/null \
    || die "could not copy $self → $XENV_DIR/bin/xenv"
  chmod +x "$XENV_DIR/bin/xenv"

  # Decide the passphrase strategy:
  #
  #   - If $XENV_KEY is set: use it as the global key for the project.
  #     Per-env env-vars ($XENV_KEY_<ENV>), if also set, win for those
  #     specific envs and get written to per-env files.
  #
  #   - If only some $XENV_KEY_<ENV> are set (no $XENV_KEY): those envs
  #     get per-env files; the remaining envs share a freshly-generated
  #     global key (written to _global.key).
  #
  #   - If nothing is pinned: generate ONE random global key. All four
  #     envs cascade-resolve via _global.key. This is the new default
  #     (was: four random per-env keys, in 0.8.0 and prior).
  #
  # Rationale: most users want one key to start. They can split a
  # specific env off later with `xenv key rotate @<env>` (which writes
  # a new per-env key and re-encrypts that env's values under it).

  # First: determine if we'll write a global key, and what its value is.
  global_key=""
  if [ -n "${XENV_KEY:-}" ]; then
    global_key=$XENV_KEY
    info "_global: using pinned passphrase from \$XENV_KEY"
  else
    # check if ANY env lacks a $XENV_KEY_<ENV> — if so, we'll need a global
    needs_global=0
    for env_name in $XENV_DEFAULT_ENVS; do
      vname=$(env_var_name "$env_name")
      eval "v=\${$vname:-}"
      [ -z "$v" ] && needs_global=1
    done
    if [ "$needs_global" = "1" ]; then
      global_key=$(openssl rand -base64 32 | tr -d '\n')
    fi
  fi

  # Write the global key first, if we have one.
  [ -n "$global_key" ] && store_key "_global" "$global_key" file >/dev/null 2>&1

  # Now walk each env: write the env README, store per-env passphrase
  # if $XENV_KEY_<ENV> is set (overrides global for that env), then
  # write the starter APP_ENV value.
  for env_name in $XENV_DEFAULT_ENVS; do
    init_env_dir "$env_name"

    salt_hex=$(openssl rand -hex "$XENV_SALT_BYTES")
    write_env_readme "$env_name" "$XENV_ITER" "$salt_hex"

    vname=$(env_var_name "$env_name")
    eval "per_env_key=\${$vname:-}"
    if [ -n "$per_env_key" ]; then
      store_key "$env_name" "$per_env_key" file >/dev/null 2>&1
      info "$env_name: using pinned passphrase from \$$vname (per-env override)"
    fi

    write_value "$env_name" "APP_ENV" "$env_name" \
      || die "could not write APP_ENV for $env_name"
  done

  info "set up $XENV_DIR/ with envs: $XENV_DEFAULT_ENVS"
  info "project id: $project_id"
  info "passphrases live in $XENV_PROJECTS_DIR/$project_id/keys/"
  info "your notes: $XENV_PROJECTS_DIR/$project_id/notes.md"
  info "each env starts with APP_ENV — try: xenv get @development APP_ENV"
}

# lookup_pinned_passphrase <env> — return $XENV_KEY_<ENV> or $XENV_KEY
# if set in the environment, else empty. Used by setup to honor
# user-pinned passphrases instead of always generating random.
lookup_pinned_passphrase() {
  env_name=$1
  vname=$(env_var_name "$env_name")
  eval "v=\${$vname:-}"
  [ -n "$v" ] && { printf '%s' "$v"; return 0; }
  [ -n "${XENV_KEY:-}" ] && { printf '%s' "$XENV_KEY"; return 0; }
  return 1
}

# adopt an existing xenv/ tree: walk each env that has values, prompt
# for the passphrase (or honor $XENV_KEY_<ENV>), MAC-verify, cache.
setup_adopt() {
  project_id=$(read_project_id) || die "no project id in $XENV_DIR/README.md — corrupt repo?"

  origin=$(cd "$XENV_DIR" && pwd)
  init_project_dir "$project_id" "$origin"

  info "adopting existing $XENV_DIR/ (project id: $project_id)"

  # walk envs/ alphabetically
  found_any=0
  for d in "$XENV_DIR"/envs/*/; do
    [ -d "$d" ] || continue
    env_name=${d%/}; env_name=${env_name##*/}
    found_any=1
    setup_adopt_one "$env_name"
  done

  if [ $found_any -eq 0 ]; then
    info "$XENV_DIR/envs/ is empty — nothing to adopt"
  fi
}

setup_adopt_one() {
  env_name=$1

  # if pinned via env var, use it; otherwise prompt
  pinned=$(lookup_pinned_passphrase "$env_name")
  if [ -n "$pinned" ]; then
    pp=$pinned
    via="\$$(env_var_name "$env_name") / \$XENV_KEY"
  else
    if [ ! -t 0 ] || [ ! -t 2 ]; then
      info "$env_name: skipped (non-tty stdin and no \$$(env_var_name "$env_name") set)"
      return 0
    fi
    pp=$(read_passphrase "passphrase for @$env_name: ") || {
      info "$env_name: skipped (read aborted)"
      return 0
    }
    via="prompt"
    [ -z "$pp" ] && { info "$env_name: skipped (empty passphrase)"; return 0; }
  fi

  # MAC-verify before caching
  verify_passphrase "$env_name" "$pp"
  case $? in
    0)
      store_key "$env_name" "$pp" file >/dev/null 2>&1
      info "$env_name: verified via $via, cached"
      ;;
    1)
      err "$env_name: passphrase did NOT match (MAC verify failed). NOT cached."
      ;;
    2)
      # no values to verify against — store the passphrase but warn
      store_key "$env_name" "$pp" file >/dev/null 2>&1
      info "$env_name: no values to MAC-verify against. Cached without verification."
      ;;
  esac
}

cmd_setup() {
  if [ -d "$XENV_DIR" ]; then
    # existing tree — adopt path
    [ -f "$XENV_DIR/$XENV_README_FILE" ] \
      || die "$XENV_DIR/ exists but no $XENV_README_FILE — corrupt? delete or fix manually"
    setup_adopt
  else
    # fresh tree — bootstrap path
    setup_fresh
  fi
}

cmd_environments() {
  [ -d "$XENV_DIR/envs" ] || { info "no $XENV_DIR/ — run 'xenv setup'"; return 0; }
  found=0
  for d in "$XENV_DIR"/envs/*/; do
    [ -d "$d" ] || continue
    name=${d%/}; name=${name##*/}
    found=1
    if lookup_key "$name" >/dev/null 2>&1; then
      printf '  %s\n' "$name"
    else
      printf '  %s  (no key)\n' "$name"
    fi
  done
  if [ $found -eq 0 ]; then
    info "no environments yet — run 'xenv key generate @<env>'"
  fi
}

cmd_key_generate() {
  env_name=$1
  backend=${2:-auto}

  if [ "$env_name" = "_global" ]; then
    # Project-wide key generation. No env dir, no env README, no
    # APP_ENV starter. Just generate the key and store it.
    key=$(openssl rand -base64 32 | tr -d '\n')
    store_key "_global" "$key" "$backend"
    printf '\nfor CI, set this secret:\n  XENV_KEY=%s\n' "$key" >&2
    return 0
  fi

  if [ -d "$(env_dir "$env_name")" ]; then
    die "env '$env_name' already exists — use 'xenv key rotate @$env_name' to change keys"
  fi

  init_env_dir "$env_name"
  salt_hex=$(openssl rand -hex "$XENV_SALT_BYTES")
  write_env_readme "$env_name" "$XENV_ITER" "$salt_hex"

  key=$(openssl rand -base64 32 | tr -d '\n')
  store_key "$env_name" "$key" "$backend"

  printf '\nfor CI, set this secret:\n  %s=%s\n' "$(env_var_name "$env_name")" "$key" >&2
}

# accept a passphrase from stdin/tty, MAC-verify against existing values,
# cache to the requested backend (default: file). Refuses to cache if the
# passphrase doesn't decrypt the existing values, unless --force.
cmd_key_set() {
  env_name=$1
  backend=${2:-auto}

  force=0
  case "$backend" in
    --force) backend=auto; force=1 ;;
  esac

  if [ "$env_name" = "_global" ]; then
    pp=$(read_passphrase "passphrase for project (_global): ") || die "no passphrase read"
    [ -n "$pp" ] || die "empty passphrase"

    # For global, verify against every env that has no per-env key
    # set. If any of those envs has values, MAC-verify under $pp. If
    # all such envs decrypt successfully (or have no values), cache.
    # On any MAC failure: refuse unless --force.
    project_id=$(read_project_id) || die "no project id"
    any_failed=0
    any_verified=0
    for d in "$XENV_DIR"/envs/*/; do
      [ -d "$d" ] || continue
      env_for_test=${d%/}; env_for_test=${env_for_test##*/}
      # skip envs with their own per-env key set anywhere
      if [ -r "$XENV_PROJECTS_DIR/$project_id/keys/$env_for_test.key" ]; then continue; fi
      verify_passphrase "$env_for_test" "$pp"
      case $? in
        0) any_verified=1 ;;
        1) any_failed=1; err "_global: passphrase does NOT decrypt @$env_for_test" ;;
        2) ;;  # no values to verify; that's fine
      esac
    done

    if [ "$any_failed" = "1" ] && [ "$force" != "1" ]; then
      die "_global: passphrase did NOT match one or more envs. Re-run with --force to cache anyway."
    fi
    [ "$any_failed" = "1" ] && err "_global: caching despite MAC failures (--force given)"
    store_key "_global" "$pp" "$backend"
    return 0
  fi

  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name' — run 'xenv key generate @$env_name' first"

  pp=$(read_passphrase "passphrase for @$env_name: ") || die "no passphrase read"
  [ -n "$pp" ] || die "empty passphrase"

  verify_passphrase "$env_name" "$pp"
  case $? in
    0)
      store_key "$env_name" "$pp" "$backend"
      ;;
    1)
      if [ "$force" -eq 1 ]; then
        store_key "$env_name" "$pp" "$backend"
        err "$env_name: passphrase did NOT match existing values, but --force given. Cached anyway."
      else
        die "$env_name: passphrase did NOT match existing values (MAC verify failed). Re-run with --force to cache anyway."
      fi
      ;;
    2)
      store_key "$env_name" "$pp" "$backend"
      info "$env_name: no values to MAC-verify against. Cached without verification."
      ;;
  esac
}

# print where the passphrase is stored. With --reveal, print the value.
cmd_key_show() {
  env_name=$1
  reveal=0
  case "${2:-}" in
    --reveal) reveal=1 ;;
  esac

  id=$(read_project_id) || die "no project id — no $XENV_DIR/$XENV_README_FILE"

  if [ "$reveal" -eq 1 ]; then
    if [ "$env_name" = "_global" ]; then
      pp=$(lookup_key_global) || die "no _global key in any backend"
    else
      pp=$(require_key "$env_name") || exit 1
    fi
    printf '%s\n' "$pp"
    return 0
  fi

  # Project-wide show: just look at the _global slots.
  if [ "$env_name" = "_global" ]; then
    if [ -n "${XENV_KEY:-}" ]; then
      printf 'env-var: \$XENV_KEY (set)\n'
      return 0
    fi
    f="$XENV_PROJECTS_DIR/$id/keys/_global.key"
    if [ -r "$f" ]; then
      printf 'file: %s\n' "$f"
      return 0
    fi
    if command -v security >/dev/null 2>&1 && \
       security find-generic-password -s xenv -a "$id/_global" >/dev/null 2>&1; then
      printf 'keychain: service=xenv, account=%s/_global\n' "$id"
      return 0
    fi
    if command -v pass >/dev/null 2>&1 && \
       pass show "xenv/$id/_global" >/dev/null 2>&1; then
      printf 'pass: xenv/%s/_global\n' "$id"
      return 0
    fi
    die "no _global passphrase set in any backend"
  fi

  # Per-env show: walk the cascade, report which slot answers.
  vname=$(env_var_name "$env_name")
  eval "v=\${$vname:-}"
  if [ -n "$v" ]; then
    printf 'env-var: \$%s (set)\n' "$vname"
    return 0
  fi
  if [ -n "${XENV_KEY:-}" ]; then
    printf 'env-var: \$XENV_KEY (via _global fallback)\n'
    return 0
  fi

  for stem_label in "$env_name:env-specific" "_global:via _global fallback"; do
    stem=${stem_label%%:*}
    note=${stem_label#*:}
    f="$XENV_PROJECTS_DIR/$id/keys/$stem.key"
    if [ -r "$f" ]; then
      printf 'file: %s (%s)\n' "$f" "$note"
      return 0
    fi
  done

  if command -v security >/dev/null 2>&1; then
    for stem_label in "$env_name:env-specific" "_global:via _global fallback"; do
      stem=${stem_label%%:*}
      note=${stem_label#*:}
      if security find-generic-password -s xenv -a "$id/$stem" >/dev/null 2>&1; then
        printf 'keychain: service=xenv, account=%s/%s (%s)\n' "$id" "$stem" "$note"
        return 0
      fi
    done
  fi
  if command -v pass >/dev/null 2>&1; then
    for stem_label in "$env_name:env-specific" "_global:via _global fallback"; do
      stem=${stem_label%%:*}
      note=${stem_label#*:}
      if pass show "xenv/$id/$stem" >/dev/null 2>&1; then
        printf 'pass: xenv/%s/%s (%s)\n' "$id" "$stem" "$note"
        return 0
      fi
    done
  fi
  die "no passphrase found for @$env_name in any backend"
}

# Helper for cmd_key_show --reveal on the global key: read the actual
# _global value from whichever backend has it, without going through
# the cascade (which would fall back to env-specific files we don't want).
lookup_key_global() {
  id=$(read_project_id 2>/dev/null) || return 1
  [ -n "${XENV_KEY:-}" ] && { printf '%s' "$XENV_KEY"; return 0; }
  f="$XENV_PROJECTS_DIR/$id/keys/_global.key"
  [ -r "$f" ] && { cat "$f"; return 0; }
  if command -v security >/dev/null 2>&1; then
    val=$(security find-generic-password -s xenv -a "$id/_global" -w 2>/dev/null) || true
    [ -n "$val" ] && { printf '%s\n' "$val"; return 0; }
  fi
  if command -v pass >/dev/null 2>&1; then
    val=$(pass show "xenv/$id/_global" 2>/dev/null) || true
    [ -n "$val" ] && { printf '%s\n' "$val"; return 0; }
  fi
  return 1
}

# remove the cached passphrase from local storage. Leaves the vault.
cmd_key_forget() {
  env_name=$1
  id=$(read_project_id) || die "no project id"

  removed=0
  f="$XENV_PROJECTS_DIR/$id/keys/$env_name.key"
  if [ -e "$f" ]; then
    rm -f "$f" && { info "removed file: $f"; removed=1; }
  fi
  if command -v security >/dev/null 2>&1 && \
     security find-generic-password -s xenv -a "$id/$env_name" >/dev/null 2>&1; then
    security delete-generic-password -s xenv -a "$id/$env_name" >/dev/null 2>&1 \
      && { info "removed keychain entry: $id/$env_name"; removed=1; }
  fi
  if command -v pass >/dev/null 2>&1 && \
     pass show "xenv/$id/$env_name" >/dev/null 2>&1; then
    pass rm -f "xenv/$id/$env_name" >/dev/null 2>&1 \
      && { info "removed pass entry: xenv/$id/$env_name"; removed=1; }
  fi

  if [ "$removed" != "1" ]; then
    if [ "$env_name" = "_global" ]; then
      info "no _global passphrase cached (already forgotten?)"
    else
      info "no cached passphrase found for @$env_name (already forgotten?)"
    fi
    return 0
  fi

  # Post-removal cascade hint: which envs (if any) are now using the
  # NEXT level of the cascade?
  if [ "$env_name" = "_global" ]; then
    affected=
    for d in "$XENV_DIR"/envs/*/; do
      [ -d "$d" ] || continue
      e=${d%/}; e=${e##*/}
      if [ ! -r "$XENV_PROJECTS_DIR/$id/keys/$e.key" ]; then
        affected="$affected $e"
      fi
    done
    if [ -n "$affected" ]; then
      info "note: envs without their own key will no longer decrypt:$affected"
    fi
  else
    if [ -r "$XENV_PROJECTS_DIR/$id/keys/_global.key" ]; then
      info "note: @$env_name now resolves via _global.key (cascade fallback)"
    else
      info "note: @$env_name has no remaining passphrase in any backend"
    fi
  fi
}

cmd_key_rotate() {
  env_name=$1

  if [ "$env_name" = "_global" ]; then
    cmd_key_rotate_global
    return $?
  fi

  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name'"

  old_pass=$(require_key "$env_name") || exit 1
  old_params=$(read_params "$env_name") || exit 1
  old_iter=${old_params%% *}
  old_salt=${old_params#* }
  read -r old_enc old_mac <<EOF
$(derive_keys "$old_pass" "$old_salt" "$old_iter")
EOF

  new_pass=$(openssl rand -base64 32 | tr -d '\n')
  new_salt=$(openssl rand -hex "$XENV_SALT_BYTES")
  new_iter=$XENV_ITER
  read -r new_enc new_mac <<EOF
$(derive_keys "$new_pass" "$new_salt" "$new_iter")
EOF

  # decrypt all to a stash first; only write new params + re-encrypt if every decrypt succeeded
  tmp_stash=$(mktemp -d "${TMPDIR:-/tmp}/xenv-rotate.XXXXXXXX") || die "mktemp failed"
  trap 'rm -rf "$tmp_stash"' EXIT INT TERM HUP

  for f in "$dir"/*"$XENV_VALUE_EXT"; do
    [ -f "$f" ] || continue
    name=${f##*/}
    plain=$(decrypt_value "$old_enc" "$old_mac" < "$f") || die "decrypt failed for $name"
    printf '%s' "$plain" > "$tmp_stash/$name"
  done

  rewrite_frontmatter "$env_name" "$new_iter" "$new_salt" \
    || die "could not rewrite README frontmatter for $env_name"

  for f in "$tmp_stash"/*; do
    [ -f "$f" ] || continue
    name=${f##*/}
    envelope=$(encrypt_value "$new_enc" "$new_mac" < "$f") \
      || die "re-encryption failed for $name"
    printf '%s\n' "$envelope" | atomic_write "$dir/$name" \
      || die "could not write $name"
  done

  rm -rf "$tmp_stash"
  trap - EXIT INT TERM HUP

  # detect which backend the old key lives in, so we update the same one
  id=$(read_project_id) || die "no project id — cannot rotate"
  backend=auto
  [ -r "$XENV_PROJECTS_DIR/$id/keys/$env_name.key" ] && backend=file
  command -v security >/dev/null 2>&1 && \
    security find-generic-password -s xenv -a "$id/$env_name" >/dev/null 2>&1 && backend=keychain
  command -v pass >/dev/null 2>&1 && \
    pass show "xenv/$id/$env_name" >/dev/null 2>&1 && backend=pass

  store_key "$env_name" "$new_pass" "$backend"
  printf '\nrotated. new key:\n  %s=%s\n' "$(env_var_name "$env_name")" "$new_pass" >&2
}

# Project-wide rotate. Walks each env that uses the _global key (no
# per-env override), decrypts ALL of them to tmpfs first (atomicity:
# every env must be readable before we commit anything), then writes
# the new global key + new params + re-encrypts. Envs with their own
# per-env key are untouched (Rule B).
cmd_key_rotate_global() {
  id=$(read_project_id) || die "no project id — cannot rotate"
  old_global=$(lookup_key_global) || die "no _global key set; nothing to rotate"

  # identify envs that resolve via _global (no per-env override)
  affected=
  for d in "$XENV_DIR"/envs/*/; do
    [ -d "$d" ] || continue
    e=${d%/}; e=${e##*/}
    # per-env file beats global; per-env keychain/pass too. Check the
    # cheap-and-common case: per-env .key file. (If a user has set a
    # per-env key via keychain/pass without a corresponding file, the
    # global rotate would incorrectly try to re-encrypt that env. For
    # 0.9.0 we accept that edge case; documented in CHANGELOG.)
    if [ ! -r "$XENV_PROJECTS_DIR/$id/keys/$e.key" ]; then
      affected="$affected $e"
    fi
  done

  if [ -z "$affected" ]; then
    info "no envs use _global; nothing to rotate"
    return 0
  fi

  info "rotating _global; affects envs:$affected"

  # ── Phase 1: decrypt every affected env's values to a tmpfs stash.
  # If ANY decrypt fails, abort — vault stays intact.
  tmp_stash=$(mktemp -d "${TMPDIR:-/tmp}/xenv-rotate-global.XXXXXXXX") || die "mktemp failed"
  trap 'rm -rf "$tmp_stash"' EXIT INT TERM HUP

  for e in $affected; do
    dir=$(env_dir "$e")
    params=$(read_params "$e") || die "$e: could not read params"
    iter=${params%% *}
    salt=${params#* }
    read -r enc mac <<EOF
$(derive_keys "$old_global" "$salt" "$iter")
EOF
    mkdir -p "$tmp_stash/$e"
    for f in "$dir"/*"$XENV_VALUE_EXT"; do
      [ -f "$f" ] || continue
      name=${f##*/}
      plain=$(decrypt_value "$enc" "$mac" < "$f") \
        || die "$e: decrypt failed for $name (old _global key wrong?)"
      printf '%s' "$plain" > "$tmp_stash/$e/$name"
    done
  done

  # ── Phase 2: generate new global, new params per env, store stash files.
  # Only happens after every decrypt above succeeded.
  new_global=$(openssl rand -base64 32 | tr -d '\n')

  for e in $affected; do
    dir=$(env_dir "$e")
    new_salt=$(openssl rand -hex "$XENV_SALT_BYTES")
    new_iter=$XENV_ITER
    read -r new_enc new_mac <<EOF
$(derive_keys "$new_global" "$new_salt" "$new_iter")
EOF
    rewrite_frontmatter "$e" "$new_iter" "$new_salt" \
      || die "could not rewrite frontmatter for $e"
    for f in "$tmp_stash/$e"/*; do
      [ -f "$f" ] || continue
      name=${f##*/}
      envelope=$(encrypt_value "$new_enc" "$new_mac" < "$f") \
        || die "$e: re-encryption failed for $name"
      printf '%s\n' "$envelope" | atomic_write "$dir/$name" \
        || die "$e: could not write $name"
    done
  done

  # ── Phase 3: store the new global. Detect the backend the old one was in.
  backend=auto
  [ -r "$XENV_PROJECTS_DIR/$id/keys/_global.key" ] && backend=file
  command -v security >/dev/null 2>&1 && \
    security find-generic-password -s xenv -a "$id/_global" >/dev/null 2>&1 && backend=keychain
  command -v pass >/dev/null 2>&1 && \
    pass show "xenv/$id/_global" >/dev/null 2>&1 && backend=pass
  store_key "_global" "$new_global" "$backend"

  rm -rf "$tmp_stash"
  trap - EXIT INT TERM HUP

  printf '\nrotated _global. new key:\n  XENV_KEY=%s\n' "$new_global" >&2
  info "rotated envs:$affected"
}

cmd_set() {
  env_name=$1
  arg=$2
  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name' — run 'xenv key generate @$env_name' first"

  case "$arg" in
    *=*)
      name=${arg%%=*}
      value=${arg#*=}
      ;;
    *)
      name=$arg
      value=$(cat)
      ;;
  esac

  [ -n "$name" ] || die "key name is empty"

  write_value "$env_name" "$name" "$value" || exit 1
  info "set $name in $dir"
}

cmd_unset() {
  env_name=$1
  name=$2
  f=$(value_file "$env_name" "$name")
  [ -f "$f" ] || die "no such key: $name"
  rm -f "$f"
  info "unset $name"
}

cmd_list() {
  env_name=$1
  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name'"

  found=0
  for f in "$dir"/*"$XENV_VALUE_EXT"; do
    [ -f "$f" ] || continue
    found=1
    name=${f##*/}
    printf '%s\n' "${name%"$XENV_VALUE_EXT"}"
  done
  [ $found -eq 0 ] && info "(no keys yet)"
}

cmd_get() {
  env_name=$1
  name=$2
  f=$(value_file "$env_name" "$name")
  [ -f "$f" ] || die "no such key: $name"

  read -r enc_key mac_key <<EOF
$(keys_for_env "$env_name")
EOF
  [ -n "$enc_key" ] || exit 1

  # Decrypt to a tmpfile first so we can:
  #   (a) reliably catch decrypt_value's exit code (a pipe or multi-
  #       command $() would mask MAC failures behind a 0 from awk),
  #   (b) preserve plaintext bytes exactly — no shell stripping of
  #       trailing newlines via command substitution.
  umask 077
  tmp=$(mktemp "${TMPDIR:-/tmp}/xenv-get.XXXXXXXX") || die "mktemp failed"
  trap 'rm -f "$tmp"' EXIT INT TERM HUP

  decrypt_value "$enc_key" "$mac_key" < "$f" > "$tmp" || die "decrypt failed"

  # interactive terminal: ensure one trailing newline so the next
  # prompt isn't glued to the value. piped / redirected: exact bytes
  # pass through, so `db=$(xenv get prod URL)` still works the same.
  tty_finish < "$tmp"

  rm -f "$tmp"
  trap - EXIT INT TERM HUP
}

cmd_edit() {
  env_name=$1
  name=$2
  dir=$(env_dir "$env_name")
  f=$(value_file "$env_name" "$name")
  [ -d "$dir" ] || die "no env '$env_name'"

  read -r enc_key mac_key <<EOF
$(keys_for_env "$env_name")
EOF
  [ -n "$enc_key" ] || exit 1

  umask 077
  tmp=$(mktemp "${TMPDIR:-/tmp}/xenv-edit.XXXXXXXX") || die "mktemp failed"
  trap 'rm -f "$tmp"' EXIT INT TERM HUP

  if [ -f "$f" ]; then
    decrypt_value "$enc_key" "$mac_key" < "$f" > "$tmp" || die "decrypt failed"
  fi

  editor=${VISUAL:-${EDITOR:-vi}}

  before=$(openssl dgst -sha256 < "$tmp" | awk '{print $NF}')
  "$editor" "$tmp"
  after=$(openssl dgst -sha256 < "$tmp" | awk '{print $NF}')

  if [ "$before" = "$after" ]; then
    info "no changes — $name unchanged"
    return 0
  fi

  envelope=$(encrypt_value "$enc_key" "$mac_key" < "$tmp") \
    || die "encryption failed — $name unchanged"
  printf '%s\n' "$envelope" | atomic_write "$f" \
    || die "could not write $f"
  info "encrypted → $f"
}

cmd_run() {
  [ $# -ge 1 ] || die "run needs <env> <cmd> [args]"
  env_name=$1
  shift
  [ $# -ge 1 ] || die "run needs a command — try 'xenv run $env_name <cmd>'"

  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name'"

  read -r enc_key mac_key <<EOF
$(keys_for_env "$env_name")
EOF
  [ -n "$enc_key" ] || exit 1

  for f in "$dir"/*"$XENV_VALUE_EXT"; do
    [ -f "$f" ] || continue
    name=${f##*/}; name=${name%"$XENV_VALUE_EXT"}
    value=$(decrypt_value "$enc_key" "$mac_key" < "$f") || die "decrypt failed for $name"
    eval "$name=\$value"
    export "$name"
  done

  exec "$@"
}

# cmd_envdump <env> — decrypt every value in <env> and print "KEY=value"
# lines to stdout, one per line. Same shape as env(1)'s output. Used
# when `xenv @<env>` is called with no following CMD; lets you peek at
# the loaded env without exec'ing anything.
#
# Values are printed verbatim, exactly as they would be exported by
# cmd_run. Multi-line values appear with their internal newlines intact;
# the consumer is responsible for any shell-quoting they need.
cmd_envdump() {
  [ $# -ge 1 ] || die "envdump needs <env>"
  env_name=$1

  dir=$(env_dir "$env_name")
  [ -d "$dir" ] || die "no env '$env_name'"

  read -r enc_key mac_key <<EOF
$(keys_for_env "$env_name")
EOF
  [ -n "$enc_key" ] || exit 1

  for f in "$dir"/*"$XENV_VALUE_EXT"; do
    [ -f "$f" ] || continue
    name=${f##*/}; name=${name%"$XENV_VALUE_EXT"}
    value=$(decrypt_value "$enc_key" "$mac_key" < "$f") || die "decrypt failed for $name"
    printf '%s=%s\n' "$name" "$value"
  done
}

# ── dispatch ──────────────────────────────────────────────────────
#
# argv contract: an `@<env>` token may appear anywhere in argv. The
# pre-scan extracts the first such token (sets $env_name from it) and
# removes it from the remaining argv. Verbs that need an env get it
# from $env_name; verbs that don't (setup, environments, help) ignore.
#
# Examples — all equivalent:
#   xenv get @production API_KEY
#   xenv @production get API_KEY
#   xenv get API_KEY @production
#
# Today the canonical form in docs is `xenv get @production API_KEY`
# (env first after verb), but any position works.

# subverb dispatcher for `xenv key ...`
cmd_key() {
  sub=${1:-}
  [ -n "$sub" ] || die "key needs a subverb: generate | set | rotate | show | forget"
  shift

  # No @<env> in argv → operate on the project-wide (_global) key.
  # With @<env> → operate on that env's key.
  if [ -z "$env_name" ]; then
    target=_global
  else
    target=$env_name
  fi

  case "$sub" in
    generate) cmd_key_generate "$target" "${1:-auto}" ;;
    set)      cmd_key_set      "$target" "${1:-auto}" ;;
    rotate)   cmd_key_rotate   "$target" ;;
    show)     cmd_key_show     "$target" "${1:-}" ;;
    forget)   cmd_key_forget   "$target" ;;
    *)        die "unknown key subverb: $sub (try: generate | set | rotate | show | forget)" ;;
  esac
}

main() {
  # pre-scan argv: extract the FIRST @<env> token, removing it from
  # argv. Subsequent @<env> tokens stay in argv as ordinary tokens
  # (a value starting with @ is preserved only if it's not the first
  # such token in argv — unavoidable corner case for now).
  env_name=
  found=0
  new_argv_count=0
  for a in "$@"; do
    if [ "$found" -eq 0 ]; then
      case "$a" in
        @?*)
          env_name=${a#@}
          found=1
          continue
          ;;
      esac
    fi
    new_argv_count=$((new_argv_count + 1))
    eval "new_argv_${new_argv_count}=\$a"
  done
  # reset $@ to the cleaned argv
  set --
  i=1
  while [ "$i" -le "$new_argv_count" ]; do
    eval "set -- \"\$@\" \"\$new_argv_$i\""
    i=$((i + 1))
  done

  cmd=${1:-}
  [ -n "$cmd" ] && shift

  # `xenv` with no verb but with @env → print the env (run-no-cmd)
  if [ -z "$cmd" ]; then
    if [ -n "$env_name" ]; then
      cmd_envdump "$env_name"
      return $?
    fi
    cmd_help
    return $?
  fi

  case "$cmd" in
    -h|--help|help)         cmd_help ;;
    -v|--version|version)   cmd_version ;;
    setup)                  cmd_setup ;;
    environments)           cmd_environments ;;
    key)                    cmd_key "$@" ;;

    set)
      [ -n "$env_name" ] || die "set needs an env: 'xenv set @<env> KEY=VALUE' (or KEY for stdin)"
      [ $# -ge 1 ] || die "set needs KEY=VALUE or KEY (stdin)"
      cmd_set "$env_name" "$1"
      ;;
    unset)
      [ -n "$env_name" ] || die "unset needs an env: 'xenv unset @<env> KEY'"
      [ $# -ge 1 ] || die "unset needs KEY"
      cmd_unset "$env_name" "$1"
      ;;
    list)
      [ -n "$env_name" ] || die "list needs an env: 'xenv list @<env>'"
      cmd_list "$env_name"
      ;;
    get)
      [ -n "$env_name" ] || die "get needs an env: 'xenv get @<env> KEY'"
      [ $# -ge 1 ] || die "get needs KEY"
      cmd_get "$env_name" "$1"
      ;;
    edit)
      [ -n "$env_name" ] || die "edit needs an env: 'xenv edit @<env> KEY'"
      [ $# -ge 1 ] || die "edit needs KEY"
      cmd_edit "$env_name" "$1"
      ;;
    run)
      [ -n "$env_name" ] || die "run needs an env: 'xenv run @<env> CMD [args]'"
      [ $# -ge 1 ] || die "run needs a command"
      cmd_run "$env_name" "$@"
      ;;

    *)
      # If we have an env but the "verb" isn't known, treat it as a
      # command to exec (the `xenv @<env> CMD [args]` shorthand).
      if [ -n "$env_name" ]; then
        cmd_run "$env_name" "$cmd" "$@"
      else
        err "unknown command: $cmd"
        err "try 'xenv help'"
        exit 1
      fi
      ;;
  esac
}

main "$@"
